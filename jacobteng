*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;background:#fff;color:#111;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;overflow:hidden;user-select:none}

/* ── shell ── */
#app{position:fixed;inset:0;display:flex;flex-direction:column}

/* ── nav ── */
#nav{position:absolute;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:48px;background:transparent}
#nav-name{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:#111;cursor:pointer;opacity:.9}
#nav-right{display:flex;gap:22px;align-items:center}
.ntab{font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:#111;opacity:.32;cursor:pointer;background:none;border:none;font-family:inherit;padding:0;transition:opacity .15s}
.ntab.on,.ntab:hover{opacity:1}

/* ── slideshow ── */
#stage{position:absolute;inset:0;overflow:hidden;background:#fff}
.slide{position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:flex-start;padding:60px 0 0 24px}
.slide img{max-width:50%;max-height:calc(100% - 80px);width:auto;height:auto;object-fit:contain;display:block;pointer-events:none;object-position:left top}
.slide.active{opacity:1;z-index:2}


.slide.hidden{opacity:0;z-index:0;pointer-events:none}

/* placeholder upload slide */
.slide-upload{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;cursor:pointer;background:#f0f0f0}
.slide-upload input{position:absolute;inset:0;opacity:0;cursor:pointer;z-index:5;width:100%;height:100%}
.slide-upload::after{content:'drop image or click +';font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(0,0,0,.25);pointer-events:none}
.slide-upload.drag-over{background:#e4e4e4}
.slide-upload.drag-over::after{color:rgba(0,0,0,.5)}
/* overlay shown on hover/drag over a filled slide */
.slide-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .18s;cursor:pointer;z-index:6;background:rgba(255,255,255,.18)}
.slide-overlay input{position:absolute;inset:0;opacity:0;cursor:pointer;z-index:3;width:100%;height:100%}
.slide-overlay::after{content:'+';font-size:28px;font-weight:200;color:rgba(0,0,0,.5);pointer-events:none}
.slide:hover .slide-overlay{opacity:1}
.slide.drag-over .slide-overlay{opacity:1;background:rgba(255,255,255,.35)}

/* ── tap zones ── */
#tap-left{position:absolute;left:0;top:0;width:45%;height:100%;z-index:50;cursor:w-resize}
#tap-right{position:absolute;right:0;top:0;width:55%;height:100%;z-index:50;cursor:e-resize}

/* ── counter ── */
#counter{position:absolute;bottom:20px;left:0;right:0;text-align:center;font-size:10px;letter-spacing:.12em;color:rgba(0,0,0,.3);z-index:100;pointer-events:none}

/* ── project title ── */
#slide-title{display:none}

/* ── panels (overview, books, info) ── */
.panel{position:absolute;inset:0;background:#f2f2ee;color:#111;overflow-y:auto;-webkit-overflow-scrolling:touch;transform:translateY(100%);transition:transform .4s cubic-bezier(.22,.61,.36,1);z-index:200}
.panel.open{transform:translateY(0)}
#panel-nav{position:sticky;top:0;display:flex;align-items:center;justify-content:space-between;padding:0 22px;height:46px;background:#fff;border-bottom:.5px solid #e0e0e0;z-index:10}
.panel-back{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:#888;cursor:pointer;background:none;border:none;font-family:inherit}
.panel-back:hover{color:#111}
.panel-title{font-size:11px;letter-spacing:.09em;text-transform:uppercase;color:#111}

/* ── overview rows ── */
.ov-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px;padding:12px}
.ov-cell{cursor:pointer;position:relative}
.ov-cell:hover .ov-thumb{opacity:1}
.ov-thumb{width:100%;aspect-ratio:3/4;object-fit:cover;display:block;background:#e8e6e2}
.ov-thumb-placeholder{width:100%;aspect-ratio:3/4;background:#e8e6e2;display:block}
.ov-meta{padding:6px 8px 14px}
.ov-range{font-size:9px;color:#b0b0b0;letter-spacing:.04em;display:block;margin-bottom:2px;font-variant-numeric:tabular-nums}
.ov-title{font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:#111;line-height:1.3;display:block}
@media(max-width:700px){.ov-grid{grid-template-columns:repeat(3,1fr);gap:8px;padding:8px}}
@media(max-width:400px){.ov-grid{grid-template-columns:repeat(2,1fr);gap:6px;padding:6px}}

/* ── bigger, centered main slideshow image on mobile ── */
@media(max-width:700px){
