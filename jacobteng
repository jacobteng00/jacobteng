function buildBooks(){
  const el=document.getElementById('books-list');
  BOOKS.forEach((b,bi)=>{
    const entry=document.createElement('div');entry.className='bentry';
    const imgs=document.createElement('div');imgs.className='bimgs';
    for(let i=0;i<b.count;i++){
      const slot=document.createElement('div');slot.className='bimg-slot';
      slot.style.cssText+=`;background:${b.color};opacity:${+(0.62+i*0.07).toFixed(2)}`;
      if(b.images[i]){const img=document.createElement('img');img.src=b.images[i];slot.appendChild(img);slot.style.opacity='1';}
      const inp=document.createElement('input');inp.type='file';inp.accept='image/*';
      inp.style.cssText='position:absolute;inset:0;opacity:0;cursor:pointer;z-index:3;width:100%;height:100%';
      inp.addEventListener('click',e=>e.stopPropagation());
      inp.addEventListener('change',e=>{
        const f=e.target.files[0];if(!f)return;
        const url=URL.createObjectURL(f);b.images[i]=url;
        slot.style.opacity='1';slot.style.background='transparent';
        let img=slot.querySelector('img');if(!img){img=document.createElement('img');slot.appendChild(img);}
        img.src=url;
      });
      slot.appendChild(inp);imgs.appendChild(slot);
    }
    const t=document.createElement('div');t.className='btitle';t.textContent=b.title;
    const m=document.createElement('div');m.className='bmeta';m.innerHTML=b.meta;
    entry.appendChild(imgs);entry.appendChild(t);entry.appendChild(m);
    el.appendChild(entry);
  });
}

/* ════════════════════════════
   INIT
════════════════════════════ */
(async()=>{
  const serverData = await loadSiteData();

  let homeSlides, homeTitle, allProjects;

  if(serverData && serverData.galleries && serverData.galleries.length){
    /* always use server data */
    const homeGallery = serverData.galleries.find(g=>g.title===serverData.homepageGallery && !g.hidden) || serverData.galleries.find(g=>!g.hidden) || serverData.galleries[0];
    homeSlides  = homeGallery ? homeGallery.images : [];
    homeTitle   = homeGallery ? homeGallery.title  : 'Portfolio';
    allProjects = serverData.galleries
      .filter(g=>!g.hidden)
      .map(g=>({
      title: g.title,
      range: '',
      strips: g.images.slice(0,4),
      slides: g.images,
    }));
    /* update info panel from server */
    if(serverData.info){
      const info=serverData.info;
      const igLink=document.querySelector('.panel-info-ig');
      const emailEl=document.querySelector('.panel-info-email');
      const aboutEl=document.querySelector('.panel-info-about');
      const clientsEl=document.querySelector('.panel-info-clients');
      if(igLink){igLink.href=info.igUrl||'#';igLink.textContent=info.ig||'';}
      if(emailEl) emailEl.textContent=info.email||'';
      if(aboutEl) aboutEl.innerHTML=(info.about||'').replace(/\n/g,'<br>');
      if(clientsEl) clientsEl.textContent=info.clients||'';
    }
  } else {
    /* server unreachable — show message */
    homeSlides  = [];
    homeTitle   = 'Jacob Teng';
    allProjects = [];
    console.warn('Could not reach server — start server.js');
  }

  /* rebuild overview with live data */
  const overviewEl=document.getElementById('overview-list');
  overviewEl.innerHTML='';
  allProjects.forEach((p,pi)=>{
    const row=document.createElement('div');row.className='prow';
    const num=document.createElement('span');num.className='pnum';num.textContent=p.range||'';
    const strips=document.createElement('div');strips.className='pstrips';
    const pal=PALS[pi%PALS.length];
    pal.forEach((c,si)=>{
      const z=document.createElement('div');z.className='szone';z.style.background=c;
      if(p.strips[si]){const img=document.createElement('img');img.src=optimizeImg(p.strips[si],'strip');z.appendChild(img);}
      strips.appendChild(z);
    });
    const title=document.createElement('span');title.className='ptitle';title.textContent=p.title;
    const arr=document.createElement('span');arr.className='parrow';arr.textContent='→';
    row.appendChild(num);row.appendChild(strips);row.appendChild(title);row.appendChild(arr);
    row.onclick=()=>{
      closePanel('overview');
      buildSlides(p.slides,p.title);
      document.getElementById('t-home').textContent=p.title;
      setTab('home');
    };
    overviewEl.appendChild(row);
  });

  window._allProjects = allProjects;

  buildSlides(homeSlides, homeTitle);
  document.getElementById('t-home').textContent=homeTitle;
  setTab('home');
})();
</script>
