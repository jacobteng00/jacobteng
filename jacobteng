/* ════════════════════════════
   SLIDESHOW ENGINE
════════════════════════════ */
let slides=[];    // array of {src, el}
let cur=0;
let curTitle='Jack Stadlman';

function makeSlideInput(srcs, i, el, onLoad){
  const inp=document.createElement('input');
  inp.type='file'; inp.accept='image/*';
  inp.style.cssText='position:absolute;inset:0;opacity:0;cursor:pointer;z-index:10;width:100%;height:100%';
  inp.addEventListener('click',e=>e.stopPropagation());
  inp.addEventListener('change',e=>{
    const f=e.target.files[0]; if(!f)return;
    const url=URL.createObjectURL(f);
    srcs[i]=url; slides[i].src=url;
    onLoad(url);
  });
  return inp;
}

function buildSlides(srcs, title){
  curTitle=title;
  cur=0;
  const stage=document.getElementById('stage');
  stage.innerHTML='';
  slides=[];

  srcs.forEach((src,i)=>{
    const el=document.createElement('div');
    el.className='slide'+(i===0?' active':' hidden');

    if(src){
      /* filled slide — image + hover overlay */
      const img=document.createElement('img');
      img.src=optimizeImg(src,'full'); img.alt=''; img.draggable=false;
      el.appendChild(img);

      const overlay=document.createElement('div');
      overlay.className='slide-overlay';
      const inp=makeSlideInput(srcs,i,el,url=>{
        img.src=url;
      });
      overlay.appendChild(inp);
      el.appendChild(overlay);
    } else {
      /* empty placeholder */
      const up=document.createElement('div');
      up.className='slide-upload';
      const inp=makeSlideInput(srcs,i,el,url=>{
        const img=document.createElement('img');
        img.src=url; img.alt=''; img.draggable=false;
        el.insertBefore(img,el.firstChild);
        // swap placeholder for overlay
        const overlay=document.createElement('div');
        overlay.className='slide-overlay';
        const inp2=makeSlideInput(srcs,i,el,url2=>{ img.src=url2; });
        overlay.appendChild(inp2);
        up.replaceWith(overlay);
      });
      up.appendChild(inp);
      el.appendChild(up);
    }

    /* drag-and-drop on every slide */
    el.addEventListener('dragover',e=>{
      if(document.querySelector('.panel.open'))return;
      e.preventDefault(); e.stopPropagation();
      el.classList.add('drag-over');
    });
    el.addEventListener('dragleave',e=>{ el.classList.remove('drag-over'); });
    el.addEventListener('drop',e=>{
      if(document.querySelector('.panel.open'))return;
      e.preventDefault(); e.stopPropagation();
      el.classList.remove('drag-over');
      const f=e.dataTransfer.files[0]; if(!f||!f.type.startsWith('image/'))return;
      const url=URL.createObjectURL(f);
      srcs[i]=url; slides[i].src=url;
      // replace whatever is in the slide with a fresh image
      const existing=el.querySelector('img');
      if(existing){ existing.src=url; }
      else{
        const img=document.createElement('img');
        img.src=url; img.alt=''; img.draggable=false;
        el.insertBefore(img,el.firstChild);
        const overlay=document.createElement('div');
        overlay.className='slide-overlay';
        const inp2=makeSlideInput(srcs,i,el,url2=>{ img.src=url2; });
        overlay.appendChild(inp2);
        const up=el.querySelector('.slide-upload');
        if(up) up.replaceWith(overlay); else el.appendChild(overlay);
      }
    });

    slides.push({src,el});
    stage.appendChild(el);
  });

  updateHUD();
}

function step(dir){
  if(document.querySelector('.panel.open'))return;
  const n=slides.length;
  if(n===0)return;
  const prev=cur;
  cur=(cur+dir+n)%n;
  if(cur===prev)return;
  slides[prev].el.classList.remove('active');
  slides[prev].el.classList.add('hidden');
  slides[cur].el.classList.remove('hidden');
  slides[cur].el.classList.add('active');
  updateHUD();
}

function updateHUD(){
  document.getElementById('counter').textContent=`${cur+1} / ${slides.length}`;
  document.getElementById('slide-title').textContent=curTitle;
}

/* ════════════════════════════
   KEYBOARD + SWIPE
════════════════════════════ */
document.addEventListener('keydown',e=>{
  if(document.querySelector('.panel.open'))return;
  if(e.key==='ArrowRight'||e.key==='ArrowDown')step(1);
  if(e.key==='ArrowLeft'||e.key==='ArrowUp')step(-1);
});

let tx0=null;
document.getElementById('stage').addEventListener('touchstart',e=>{tx0=e.touches[0].clientX;},{passive:true});
document.getElementById('stage').addEventListener('touchend',e=>{
  if(tx0===null)return;
  const dx=e.changedTouches[0].clientX-tx0;
  if(Math.abs(dx)>40)step(dx<0?1:-1);
  tx0=null;
});

