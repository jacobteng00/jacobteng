function optimizeImg(src, type='full'){
  if(!src || !src.includes('res.cloudinary.com')) return src;
  // insert transformation after /upload/
  const transforms = {
    full:   'f_auto,q_auto,w_1600',   // full slideshow image
    thumb:  'f_auto,q_auto,w_400',    // overview grid thumbnails
    strip:  'f_auto,q_auto,w_136',    // list strip thumbnails
  };
  const t = transforms[type] || transforms.full;
  return src.replace('/upload/', `/upload/${t}/`);
}
