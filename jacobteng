  document.getElementById('panel-'+id).classList.add('open');
  if(id==='overview') buildOverview(window._allProjects||[]);
  setTab(id);
}
function closePanel(id){
  document.getElementById('panel-'+id).classList.remove('open');
  setTab('home');
}
function setTab(which){
  ['home','overview','info'].forEach(t=>document.getElementById('t-'+t).classList.toggle('on',t===which));
}
function goHome(){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('open'));
  buildSlides(HOME_SLIDES.map(s=>s.src),'Jack Stadlman');
  setTab('home');
}

/* ════════════════════════════
   OVERVIEW
════════════════════════════ */
function buildOverview(projects){
  const el=document.getElementById('overview-list');
  el.innerHTML='';
  if(!projects||!projects.length) return;
  projects.forEach((p,pi)=>{
    const cell=document.createElement('div');
    cell.className='ov-cell';

    const imgs = (p.slides||[]).filter(s=>s);
    let imgIdx = 0;

    const coverSrc = imgs[0] || '';
    if(coverSrc){
      const img=document.createElement('img');
      img.className='ov-thumb';
      img.src=optimizeImg(coverSrc,'thumb');
      img.alt=p.title;
      img.loading='lazy';
      cell.appendChild(img);

      /* hover advances to next image and stays */
      if(imgs.length > 1){
        cell.addEventListener('mouseenter', ()=>{
          imgIdx = (imgIdx + 1) % imgs.length;
          img.src = optimizeImg(imgs[imgIdx],'thumb');
        });
      }
    } else {
      const ph=document.createElement('div');
      ph.className='ov-thumb-placeholder';
      ph.style.background=PALS[pi%PALS.length][0];
      cell.appendChild(ph);
    }

    const meta=document.createElement('div');meta.className='ov-meta';
    const range=document.createElement('span');range.className='ov-range';range.textContent=p.range||'';
    const title=document.createElement('span');title.className='ov-title';title.textContent=p.title;
    meta.appendChild(range);meta.appendChild(title);
    cell.appendChild(meta);

    cell.onclick=()=>{
      closePanel('overview');
      buildSlides(p.slides,p.title);
      document.getElementById('t-home').textContent=p.title;
      setTab('home');
    };
    el.appendChild(cell);
  });
}

